{
  "name": "ru-rsfsr-app",
  "version": "1.0.0",
  "description": "Мобильное приложение Цифровой Платформы РСФСР",
  "author": "Кагиров Абдул-Хаким Ахмадович",
  "license": "PROPRIETARY",
  "private": true,
  "main": "../../Приложение/index.html",
  "scripts": {
    "init": "npm install && npx cap sync",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:build": "cd android && ./gradlew bundleRelease",
    "android:apk": "cd android && ./gradlew assembleRelease",
    "ios:open": "npx cap open ios",
    "ios:run": "npx cap run ios",
    "ios:archive": "cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release archive -archivePath build/App.xcarchive",
    "ios:export": "cd ios/App && xcodebuild -exportArchive -archivePath build/App.xcarchive -exportPath build -exportOptionsPlist ExportOptions.plist",
    "windows:open": "cd windows && start App.sln",
    "windows:build": "cd windows && msbuild App.sln /p:Configuration=Release /p:Platform=x64",
    "windows:package": "cd windows && msbuild App.sln /t:Publish /p:Configuration=Release /p:Platform=x64 /p:AppxBundlePlatforms=\"x64|arm64\" /p:AppxBundle=Always /p:UapAppxPackageBuildMode=StoreUpload",
    "sync": "npx cap sync",
    "copy": "npx cap copy",
    "update": "npx cap update",
    "doctor": "npx cap doctor"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/biometric-auth": "^6.0.0",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "capacitor-secure-storage-plugin": "^0.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/assets": "^3.0.5",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
